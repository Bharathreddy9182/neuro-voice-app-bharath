{
  "name": "web-selenium-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade End-to-End Web Automation Framework using Selenium WebDriver, Node.js, Mocha, Chai, ExcelJS, Winston, and GitHub Actions.",
  "main": "index.js",
  "scripts": {
    "test": "mocha --config .mocharc.json \"tests/**/*.test.js\"",
    "test:smoke": "cross-env SUITE=smoke mocha --config .mocharc.json \"tests/smoke/**/*.test.js\"",
    "test:regression": "cross-env SUITE=regression mocha --config .mocharc.json \"tests/regression/**/*.test.js\"",
    "test:auth": "mocha --config .mocharc.json \"tests/regression/auth_web.test.js\"",
    "report:excel": "node scripts/generate_excel_report.js",
    "clean:reports": "rimraf reports/*.html reports/*.json reports/*.xlsx reports/screenshots reports/failures"
  },
  "keywords": [
    "selenium",
    "selenium-webdriver",
    "web-automation",
    "testing",
    "mocha",
    "chai",
    "exceljs",
    "nodejs"
  ],
  "author": "Web QA Automation Architect",
  "license": "ISC",
  "dependencies": {
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "chromedriver": "^126.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "path": "^0.12.7",
    "rimraf": "^5.0.7",
    "selenium-webdriver": "^4.22.0",
    "winston": "^3.13.0"
  }
}
